
### General ###

# Print the HTTP and FTP server responses
server_response = on

# Use the server-provided modified date
timestamping = on

# Trust the Content Disposition header if available, if not, use the filename from the final URL
content_disposition = on
trust_server_names = on

# Don't store HSTS domains
hsts = off


### Error handling ###

# Set timeouts
dns_timeout = 5
connect_timeout = 5
read_timeout = 120

# Retry 5 times if a download fails
tries = 5

# Retry even when the connection was refused (this fails fast so there's no harm in trying it a few times)
retry_connrefused = on


### Scraping ###

# Alway stay under the requested URL for recursive downloads
no_parent = on

# Follow FTP links from HTML documents
follow_ftp = on

# Ignore robots.txt and other directives
robots = off

# Add proper extensions for text/html, text/css, and some others if they don't have one already
adjust_extension = on
