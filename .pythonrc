#!/usr/bin/env python

import sys
if sys.version_info >= (3, 8):
    # Load wat
    # https://github.com/igrek51/wat
    import base64, zlib
    code = b''
    exec(zlib.decompress(base64.b64decode(code)).decode(), globals())

    # hide helper functions in a utility class to avoid littering the global namespace
    # keep imports inline to only pay for them if needed (and not have them bleed into the global namespace)
    class _Utils:

        class Color:
            BLACK   = 30
            RED     = 31
            GREEN   = 32
            YELLOW  = 33
            BLUE    = 34
            MAGENTA = 35
            CYAN    = 36
            WHITE   = 37

        @staticmethod
        def color(text, color=None):
            if color:
                return f"\033[{color}m{text}\033[0m"
            return f"{text}\033[0m"

        @classmethod
        def paste(cls):
            import inspect
            print(cls.color("Paste code now (ctrl+d when done)", cls.Color.GREEN))
            exec(inspect.cleandoc("\n" + sys.stdin.read()), globals())

        @classmethod
        def run_shell_cmd(cls, cmd):
            import shlex
            args = shlex.split(cmd)
            # special case for cd to change the directory
            if args and args[0] == "cd":
                try:
                    if len(args) == 1:
                        args.append("~")
                    elif len(args) > 2:
                        raise Exception("too many arguments")
                    os.chdir(os.path.expanduser(args[1]))
                    print(os.getcwd())
                except Exception as e:
                    print(cls.color(f"{cmd}: {e}", cls.Color.RED))
            else:
                import subprocess
                p = subprocess.run(cmd, shell=True, text=True, capture_output=True)
                if p.stdout:
                    print(p.stdout)
                if p.stderr:
                    print(cls.color(p.stderr, cls.Color.RED))
                #print(cls.color(repr(p), cls.Color.GREEN if not p.returncode else cls.Color.RED))
                return p

        @classmethod
        def excepthook(cls, type_, value, tb):
            if (
                type_ == SyntaxError
                and (value.filename == "<stdin>" or value.filename.startswith("<python-input-"))
                and value.lineno == 1
                and value.offset == 1
                and value.text.startswith("!")
            ):
                import builtins
                builtins._ = cls.run_shell_cmd(value.text[1:])
            else:
                import traceback
                print(cls.color("".join(traceback.format_exception(value)), cls.Color.RED), end="")

    # put things in the global namespace
    paste = _Utils.paste
    sys.excepthook = _Utils.excepthook
    sys.ps1 = f"\001\033[36m\002>>>\001\033[0m\002 "
    sys.ps2 = f"\001\033[35m\002...\001\033[0m\002 "

    # clean up reference to class
    del globals()["_Utils"]

    print("""\
---------------------
Extra commands:
 - paste(): easier pasting of code blocks
 - wat: wat/<obj> for inspection
 - Use ! for shell (ex: !ls)
---------------------\
""")
